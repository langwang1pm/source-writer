 # ============================================
 # source-writer 环境变量配置模板
 # 复制为 .env 并填入真实值后执行 docker compose up
 # ============================================

 # ---------- 项目标识 ----------
 COMPOSE_PROJECT_NAME=source-writer

 # ---------- 数据库（PGX 服务器上已有的 PostgreSQL） ----------
 DATABASE_HOST=host.docker.internal
 DATABASE_PORT=5432
 DATABASE_NAME=icoastline
 DATABASE_USER=postgres
 DATABASE_PASSWORD=your_password
 DATABASE_SCHEMA=sourcewriter
 DATABASE_URL=postgresql+asyncpg://postgres:your_password@host.docker.internal:5432/icoastline

 # ---------- Dify 配置（PGX 服务器上已有的 Dify） ----------
 DIFY_BASE_URL=http://host.docker.internal

 # Dify chatflow (生成文档 chatflow) API Key
 DIFY_APP_API_KEY=app-xxxxxxxxxxxxxxxx

 # Dify Dataset API Key
 DIFY_DATASET_API_KEY=dataset-xxxxxxxxxxxxxxxx

 # 知识库 ID
 DIFY_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

 DIFY_INDEXING_TECHNIQUE=high_quality
 DIFY_PROCESS_RULE_MODE=automatic
 DIFY_DOC_FORM=text_model

 # Dify Workflow (上传文档解析处理)
 DIFY_WORKFLOW_API_KEY=app-xxxxxxxxxxxxxxxx
 DIFY_WORKFLOW_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

 # Dify retrieval & embedding
 DIFY_RERANKING_ENABLE=false
 DIFY_SCORE_THRESHOLD=0.3
 DIFY_EMBEDDING_MODEL=qwen3-embedding:4b
 DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/ollama/ollama

 # ---------- 文件存储 ----------
 # 后端写入路径（容器内），对应 compose volume 挂载点
 UPLOAD_DIR=/app/uploads

 # ---------- OnlyOffice ----------
 DIFY_OFFICE_BASE_URL=http://host.docker.internal:8080
 DIFY_OFFICE_SECRET=your_onlyoffice_jwt_secret
 DIFY_PUBLIC_URL=http://host.docker.internal:8002

 # ---------- 前端构建（build arg，浏览器访问后端的地址） ----------
VITE_API_BASE_URL=http://your-server-ip
VITE_API_BASE_URL=http://your-server-ip:3000
FRONTEND_PORT=3000
