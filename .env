 # ============================================
 # source-writer 生产环境配置
 # 由后端 backend/.env 适配为 Docker Compose 部署
 # ============================================
 COMPOSE_PROJECT_NAME=source-writer

 # ---------- 数据库（PGX 服务器上已有的 PostgreSQL） ----------
 DATABASE_HOST=host.docker.internal
 DATABASE_PORT=31102
 DATABASE_NAME=icoastline
 DATABASE_USER=icoastline
 DATABASE_PASSWORD=icoastline
 DATABASE_SCHEMA=sourcewriter
 DATABASE_URL=postgresql+asyncpg://icoastline:icoastline@host.docker.internal:31102/icoastline

 # ---------- Dify 配置（PGX 服务器上已有的 Dify） ----------
 DIFY_BASE_URL=http://host.docker.internal
 DIFY_APP_API_KEY=app-TL1ujTicUWVo5zV8jp1PRx7x
 DIFY_DATASET_API_KEY=dataset-FPexjNsYAVV1aQZC9l5XMqtp
 DIFY_DATASET_ID=30bb8d5d-e388-4caa-93f5-e3b04cc27569

 DIFY_INDEXING_TECHNIQUE=high_quality
 DIFY_PROCESS_RULE_MODE=hierarchical
 DIFY_DOC_FORM=hierarchical_model

 DIFY_WORKFLOW_API_KEY=app-HLcM7mrhSjfCrOu8F4O6bg5X
 DIFY_WORKFLOW_APP_ID=e49dd3ae-b934-4540-b4f8-d41f34d40c51

 DIFY_RERANKING_ENABLE=false
 DIFY_SCORE_THRESHOLD=0.3
 DIFY_EMBEDDING_MODEL=qwen3-embedding:4b
 DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/ollama/ollama

 # ---------- 文件存储 ----------
 UPLOAD_DIR=/app/uploads

# ---------- OnlyOffice ----------
DIFY_OFFICE_BASE_URL=http://localhost:8080
DIFY_OFFICE_SECRET=patentwriter_jwt_secret_2026
DIFY_PUBLIC_URL=http://localhost:3000

# ---------- 前端构建（浏览器访问后端的地址） ----------
FRONTEND_PORT=3000

ONLYOFFICE_PORT=8080
